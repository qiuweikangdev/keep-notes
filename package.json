{
  "name": "keep-notes",
  "type": "module",
  "version": "2.0.0",
  "description": "Markdown编辑器笔记软件",
  "author": "example.com",
  "homepage": "https://electron-vite.org",
  "main": "./out/main/index.js",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "start": "electron-vite preview",
    "dev": "nodemon --exec electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux",
    "lint-staged": "lint-staged",
    "prepare": "husky install",
    "commit": "git-cz",
    "update": "pnpm dlx taze -w"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^3.0.0",
    "@milkdown/core": "^7.5.0",
    "@milkdown/crepe": "^7.5.0",
    "@milkdown/kit": "^7.5.0",
    "@milkdown/preset-commonmark": "^7.5.0",
    "@milkdown/preset-gfm": "^7.5.0",
    "@milkdown/prose": "^7.5.0",
    "@milkdown/react": "^7.5.0",
    "@milkdown/theme-nord": "^7.5.0",
    "@milkdown/utils": "^7.5.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "dayjs": "^1.11.20",
    "electron-localshortcut": "^3.2.1",
    "electron-updater": "^6.8.3",
    "lodash-es": "^4.17.21",
    "lucide-react": "^0.400.0",
    "pinyin-pro": "^3.28.1",
    "radix-ui": "^1.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-resizable-panels": "^2.1.0",
    "simple-git": "^3.36.0",
    "tailwind-merge": "^2.4.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config": "^1.0.2",
    "@electron-toolkit/eslint-config-ts": "^1.0.1",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@types/electron-localshortcut": "^3.1.3",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^18.19.130",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.5.0",
    "commitizen": "^4.3.1",
    "cz-git": "^1.13.1",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "eslint": "^8.57.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "nodemon": "^3.1.14",
    "postcss": "^8.4.38",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vite": "^5.4.21"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx}": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git"
    }
  }
}
