{
  "name": "keep-notes",
  "version": "2.13.0",
  "description": "Markdown编辑器笔记软件",
  "homepage": "https://github.com/qiuweikangdev/keep-notes",
  "author": "qiuweikangdev",
  "repository": {
    "type": "git",
    "url": "https://github.com/qiuweikangdev/keep-notes.git"
  },
  "packageManager": "pnpm@11.10.0",
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "format": "oxfmt --write",
    "format:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "start": "electron-vite preview",
    "predev": "node scripts/ensure-electron.mjs",
    "dev": "nodemon --exec electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps && node scripts/sign-electron-dev.mjs",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux",
    "sign": "./scripts/sign-app.sh",
    "dev:signed": "./scripts/dev-signed.sh",
    "lint-staged": "lint-staged",
    "prepare": "husky install",
    "commit": "git-cz",
    "update": "pnpm dlx taze -w",
    "semantic-release": "semantic-release",
    "semantic-release:dry-run": "semantic-release --dry-run"
  },
  "dependencies": {
    "@blocknote/core": "^0.51.4",
    "@blocknote/mantine": "^0.51.4",
    "@blocknote/react": "^0.51.4",
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "6.2.1",
    "@codemirror/language": "^6.12.4",
    "@codemirror/state": "^6.7.0",
    "@codemirror/view": "^6.43.3",
    "@dnd-kit/core": "^6.3.1",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^3.0.0",
    "@lezer/highlight": "^1.2.3",
    "@mantine/core": "^9.4.0",
    "@mantine/hooks": "^9.4.0",
    "@mantine/utils": "^6.0.22",
    "@pierre/diffs": "1.1.22",
    "@tanstack/react-virtual": "^3.14.3",
    "@tiptap/pm": "3.27.1",
    "builder-util-runtime": "^9.7.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.21",
    "diff": "8.0.3",
    "electron-localshortcut": "^3.2.1",
    "electron-updater": "^6.8.9",
    "html-to-docx": "^1.8.0",
    "lodash-es": "^4.18.1",
    "lucide-react": "^0.400.0",
    "markdown-it": "^14.2.0",
    "nodemailer": "^9.0.1",
    "pinyin-pro": "^3.28.1",
    "radix-ui": "^1.6.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-resizable-panels": "^2.1.9",
    "simple-git": "^3.36.0",
    "tailwind-merge": "^2.6.1",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.9",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.20",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.1.0",
    "@testing-library/user-event": "14.5.2",
    "@types/lodash-es": "^4.17.12",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.13.2",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.5.2",
    "commitizen": "^4.3.2",
    "cz-git": "^1.13.1",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "husky": "^9.1.7",
    "jsdom": "25.0.1",
    "lint-staged": "^15.5.2",
    "nodemon": "^3.1.14",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "postcss": "^8.5.15",
    "semantic-release": "^25.0.5",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vite": "^7.3.6",
    "vitest": "3.2.6"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx}": [
      "oxfmt --write",
      "oxlint --fix"
    ]
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git"
    }
  },
  "productName": "Keep Notes"
}
